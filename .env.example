# Server
NODE_ENV=development
HOST=0.0.0.0
PORT=3000
LOG_LEVEL=info

# Database & Storage
DB_FILE=/app/data/data.db
UPLOAD_DIR=/app/uploads

# JWT & Auth
JWT_SECRET=change_this_in_production
API_KEY=
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme123

# Security
CSRF_ENABLED=true
CSRF_SECRET=change_this_in_production
CSRF_COOKIE_SECURE=false
TRUST_PROXY=0

# HTTPS & HSTS
FORCE_HTTPS=true
HSTS_ENABLED=true
PUBLIC_URL=https://localhost:3000
SSL_CERT_PATH=/app/certs/cert.pem
SSL_KEY_PATH=/app/certs/key.pem

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8825

# Email (SMTP)
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USER=
SMTP_FROM=no-reply@gestor-tareas.local

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=900000

# API Public
PUBLIC_HOST=localhost:3000
PUBLIC_API_IDENTIFIER=gestor-tareas-api

# Image Handling
ALLOW_HTTP_IMAGES=false

# Backup/Maintenance
BACKUP_DIR=/app/data/backups
SHUTDOWN_GRACE_MS=3000
SHUTDOWN_FORCE_MS=6000

# Advanced (optional)
SNAPSHOT_EXCLUDE=node_modules,uploads
DRY_RUN=false
PRUNE=false
MAX_DELETE=1000

# ===== PARA PRODUCCIÓN: CAMBIAR A BREVO =====
# Descomenta y actualiza estas líneas con tus credenciales de Brevo
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=tu_email@smtp-brevo.com
# SMTP_PASS=tu_brevo_password
# Luego comenta las líneas de Mailpit arriba
